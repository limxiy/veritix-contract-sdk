{
  "name": "@veritix/contract-sdk",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript client SDK for the VeriTix Soroban smart contract on the Stellar network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublish": "npm run build"
  },
  "keywords": [
    "stellar",
    "soroban",
    "smart-contract",
    "sdk",
    "veritix",
    "escrow",
    "payments"
  ],
  "author": "VeriTix Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/veritix/contract-sdk.git"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
